# NREL/AFDC API – get free key at developer.nlr.gov
AFDC_API_KEY=

# Snowflake connection
# SNOWFLAKE_ACCOUNT format: orgname-accountname (find in Snowsight → Admin → Accounts)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
# SNOWFLAKE_PRIVATE_KEY_PATH: path to the .p8 private key file for CHARGE_INTEL_SVC
# (used for local dev and GitHub Actions, which writes the key secret to a file first)
SNOWFLAKE_PRIVATE_KEY_PATH=
# SNOWFLAKE_PRIVATE_KEY: raw PEM contents of the same key, used instead of the path
# above when there's no filesystem to point at (e.g. Streamlit Cloud secrets.toml)
SNOWFLAKE_PRIVATE_KEY=
SNOWFLAKE_WAREHOUSE=CHARGE_INTEL_WH
SNOWFLAKE_DATABASE=CHARGE_INTEL_CANADA
SNOWFLAKE_ROLE=CHARGE_INTEL_ROLE

# GitHub Actions uses these same names as repository secrets.
# On Streamlit Cloud, set these same keys (top-level, not under a [section]) in the
# app's Secrets panel — snowflake_conn.py reads st.secrets directly.
