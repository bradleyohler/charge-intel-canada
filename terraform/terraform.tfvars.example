# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored – never commit it.

snowflake_organization_name = "myorg"              # the part before the dash
snowflake_account_name      = "myaccount"          # the part after the dash
snowflake_admin_user        = "TERRAFORM_SVC"
snowflake_private_key_path  = "terraform_svc_key.p8"  # path to your .p8 private key file
snowflake_region            = "us-east-1"
